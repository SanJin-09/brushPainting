{
  "start_urls": [
    "https://commons.wikimedia.org/wiki/Category:Qiu_Ying",
    "https://commons.wikimedia.org/wiki/Category:Spring_Morning_in_the_Han_Palace",
    "https://commons.wikimedia.org/wiki/Category:A_Scroll_of_Tribute_by_Qiu_Ying"
  ],
  "allowed_domains": [
    "wikimedia.org"
  ],
  "output_dir": "runtime/reference_scrape/wikimedia_qiu_ying",
  "request_delay_seconds": 1.0,
  "timeout_seconds": 20,
  "max_pages": 120,
  "max_images": 80,
  "min_image_bytes": 100000,
  "respect_robots_txt": true,
  "page_url_allow_patterns": [
    "Category:(Qiu_Ying|Spring_Morning_in_the_Han_Palace|A_Scroll_of_Tribute_by_Qiu_Ying)",
    "/wiki/File:",
    "pagefrom="
  ],
  "page_url_deny_patterns": [
    "action=edit",
    "Special:",
    "Template:",
    "User:",
    "Talk:",
    "MediaWiki:",
    "Help:"
  ],
  "image_url_allow_patterns": [
    "upload\\.wikimedia\\.org/.+\\.(jpg|jpeg|png|tif|tiff|webp)$"
  ],
  "image_url_deny_patterns": [
    "/thumb/",
    "icon",
    "logo",
    "\\.svg($|\\?)"
  ],
  "headers": {
    "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8"
  }
}
