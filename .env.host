APP_ENV=development
DATABASE_URL=sqlite:///./runtime/db.sqlite
REDIS_URL=redis://127.0.0.1:6380/0
RQ_QUEUE_NAME=gpu
RQ_MAX_QUEUED_JOBS=50

RUNTIME_ROOT=./runtime
PUBLIC_MEDIA_BASE=http://127.0.0.1:8000/media
MAX_UPLOAD_FILES=5
MAX_UPLOAD_BYTES=20971520
MAX_IMAGE_EDGE=8192
THUMBNAIL_MAX_EDGE=480

MODEL_BACKEND=mock
QWEN_EDIT_MODEL_PATH=$PWD/runtime/models/qwen_image_edit_2511
QWEN_IMAGE_COMPONENTS_PATH=$PWD/runtime/models/qwen_image
QWEN_EDIT_PROCESSOR_PATH=$PWD/runtime/models/qwen_image_edit/processor
GONGBI_LORA_PATH=$PWD/runtime/models/lora/qwen_image_edit_2511_gongbi_lora_v1.safetensors
GONGBI_LORA_SCALE=1.0
QWEN_IMAGE_STEPS=40

# SAM 3: mock / sam3 / disabled. Keep preload off to avoid blocking worker startup.
SAM3_BACKEND=mock
SAM3_PRELOAD=false
SAM3_CHECKPOINT_PATH=$PWD/runtime/models/sam3/sam3.pt
SAM3_DEVICE=cuda
SAM3_SCORE_THRESHOLD=0.30
SEGMENT_MAX_RESULTS=12
SEGMENT_MIN_AREA_RATIO=0.015

PYTHONPATH=$PWD:$PWD/services/model_runtime
VITE_API_BASE=http://127.0.0.1:8000/api
