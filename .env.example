# Core
APP_ENV=development
APP_PORT=8000
WEB_PORT=5173
REDIS_HOST_PORT=6380

# SQLite + RQ
DATABASE_URL=sqlite:////app/runtime/db.sqlite
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=gpu
RQ_MAX_QUEUED_JOBS=50

# Storage and upload limits
RUNTIME_ROOT=/app/runtime
PUBLIC_MEDIA_BASE=http://localhost:8000/media
MAX_UPLOAD_FILES=5
MAX_UPLOAD_BYTES=20971520
MAX_IMAGE_EDGE=8192
THUMBNAIL_MAX_EDGE=480

# Local development: mock. Production: diffsynth_qwen.
MODEL_BACKEND=mock
MODEL_DEVICE=cuda
QWEN_EDIT_MODEL_PATH=/models/qwen_image_edit_2511
QWEN_IMAGE_COMPONENTS_PATH=/models/qwen_image
QWEN_EDIT_PROCESSOR_PATH=/models/qwen_image_edit/processor
GONGBI_LORA_PATH=/models/lora/qwen_image_edit_2511_gongbi_lora_v1.safetensors
GONGBI_LORA_SCALE=1.0
QWEN_IMAGE_STEPS=40
MODEL_HOST_PATH=./runtime/models

# SAM 3: mock / sam3 / disabled. Keep preload off to avoid blocking worker startup.
SAM3_BACKEND=mock
SAM3_PRELOAD=false
SAM3_MODEL_SOURCE=modelscope
SAM3_CHECKPOINT_PATH=/models/sam3/sam3.pt
SAM3_MODELSCOPE_MODEL_ID=facebook/sam3
SAM3_MODELSCOPE_REVISION=master
SAM3_MODELSCOPE_LOCAL_DIR=/app/runtime/models/sam3
SAM3_MODELSCOPE_CHECKPOINT_FILENAME=sam3.pt
SAM3_MODELSCOPE_DOWNLOAD_FULL=false
SAM3_DEVICE=cuda
SAM3_AMP_DTYPE=bfloat16
SAM3_SCORE_THRESHOLD=0.30
SEGMENT_MAX_RESULTS=12
SEGMENT_MIN_AREA_RATIO=0.015

# Frontend
VITE_API_BASE=http://localhost:8000/api
