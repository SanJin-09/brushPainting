# Core
APP_ENV=development
APP_PORT=8000
WEB_PORT=5173
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
MINIO_API_HOST_PORT=9010
MINIO_CONSOLE_HOST_PORT=9011

# Database
DATABASE_URL=postgresql+psycopg://gongbi:gongbi@postgres:5432/gongbi

# Queue
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Storage
MEDIA_ROOT=/app/runtime/media
PUBLIC_MEDIA_BASE=http://localhost:8000/media

# MinIO (reserved for object storage adapter)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gongbi
MINIO_SECURE=false
MODEL_HOST_PATH=./runtime/models

# Model Runtime
MODEL_DEVICE=cuda
MODEL_PRECISION=bf16
MODEL_ROOT=/models
MODEL_BACKEND=qwen_image
QWEN_IMAGE_MODEL_PATH=/models/qwen_image_edit_2511
STYLE_CONFIG_PATH=/app/configs/styles/gongbi_default.yaml
DEFAULT_STYLE_ID=gongbi_default
MASK_ASSIST_BACKEND=mock
SAM_MODEL_PATH=/models/sam/sam_vit_b.pth

# Generation Defaults
QWEN_IMAGE_STEPS=40
QWEN_IMAGE_TRUE_CFG_SCALE=4.0
QWEN_IMAGE_GUIDANCE_SCALE=1.0
Z_IMAGE_MODEL_PATH=/models/z_image
Z_IMAGE_STEPS=32
Z_IMAGE_SIZE=1536
Z_IMAGE_CFG=4.0
Z_IMAGE_IMG2IMG_STRENGTH=0.45
Z_IMAGE_INPAINT_STRENGTH=1.0
INPAINT_CONTEXT_PAD=96
INPAINT_MASK_FEATHER=16

# Frontend
VITE_API_BASE=http://localhost:8000/api/v1
